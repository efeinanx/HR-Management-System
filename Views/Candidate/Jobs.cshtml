@model JobSearchViewModel
@{
    ViewData["Title"] = "Job search";
    var cities = (IEnumerable<string>)ViewBag.Cities;
    var appliedIds = ViewBag.AppliedJobIds as HashSet<int> ?? new HashSet<int>();
}
<h1 class="h3 mb-3">Job search</h1>
<form method="get" class="hrm-card p-3 mb-4">
    <div class="row g-2 align-items-end">
        <div class="col-md-5">
            <label asp-for="Query" class="form-label small text-muted mb-1">Keywords</label>
            <input asp-for="Query" class="form-control" placeholder="Title or description" />
        </div>
        <div class="col-md-4">
            <label asp-for="Location" class="form-label small text-muted mb-1">Location</label>
            <select asp-for="Location" class="form-select">
                <option value="">All cities</option>
                @foreach (var city in cities)
                {
                    <option value="@city">@city</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn hrm-btn-primary w-100">Search</button>
        </div>
    </div>
</form>
@if (Model.Results.Count == 0)
{
    <p class="text-secondary">No jobs match your filters.</p>
}
else
{
    <div class="table-responsive hrm-card">
        <table class="table table-hover mb-0 hrm-table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Company</th>
                    <th>Location</th>
                    <th>Type</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var j in Model.Results)
            {
                <tr>
                    <td>@j.Title</td>
                    <td><a asp-controller="Companies" asp-action="Details" asp-route-id="@j.CompanyProfileId">@j.Company.CompanyName</a></td>
                    <td>@j.Location</td>
                    <td>@j.EmploymentType</td>
                    <td class="text-end">
                        @if (appliedIds.Contains(j.Id))
                        {
                            <span class="btn btn-sm btn-secondary disabled">Already applied</span>
                        }
                        else
                        {
                            <a class="btn btn-sm btn-outline-dark" asp-action="Apply" asp-route-id="@j.Id">Apply</a>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
