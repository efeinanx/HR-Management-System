<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — BEY HR</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/hrm-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HrmApp.styles.css" asp-append-version="true" />
</head>
<body class="hrm-body d-flex flex-column">
    @inject UserManager<ApplicationUser> UserManager
    @{
        var currentUser = await UserManager.GetUserAsync(User);
        var displayName = currentUser?.DisplayName ?? User.Identity?.Name;
    }
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark hrm-navbar hrm-navbar-bey mb-0">
            <div class="container-fluid px-3 px-lg-4 bey-nav-shell">
                <a class="navbar-brand d-flex align-items-center py-1 py-lg-2" asp-controller="Home" asp-action="Index" title="BEY HR">
                    <img src="~/images/bey-hr-logo.png" alt="BEY HR Human Resources" class="bey-brand-logo" asp-append-version="true" />
                </a>
                <button class="navbar-toggler border-0 ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav bey-nav-links py-2 py-lg-0 align-items-lg-center gap-lg-1 justify-content-lg-center">
                        <li class="nav-item">
                            <a class="nav-link px-3 rounded-pill bey-nav-pill" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 rounded-pill bey-nav-pill" asp-controller="Home" asp-action="About">About</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 rounded-pill bey-nav-pill" asp-controller="Home" asp-action="Contact">Contact</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav bey-nav-actions align-items-lg-center gap-2 pb-3 pb-lg-0 justify-content-lg-end">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="nav-link small text-white-50 mb-0">@displayName</span>
                            </li>
                            <li class="nav-item">
                                <form class="d-inline" asp-controller="Account" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-light btn-sm rounded-pill px-3">Sign out</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-light btn-sm rounded-pill px-3" asp-controller="Account" asp-action="Login">Sign in</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn hrm-btn-primary btn-sm rounded-pill px-3" asp-controller="Account" asp-action="Register">Sign up</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <main role="main" class="flex-grow-1">
        @if (ViewData["FullWidthMain"] as bool? == true)
        {
            @if (TempData["Message"] is string flashFull && !string.IsNullOrEmpty(flashFull))
            {
                <div class="container pt-4">
                    <div class="alert alert-success border-0 hrm-card" role="alert">@flashFull</div>
                </div>
            }
            @RenderBody()
        }
        else
        {
            <div class="container py-4">
                @if (TempData["Message"] is string flash && !string.IsNullOrEmpty(flash))
                {
                    <div class="alert alert-success border-0 hrm-card" role="alert">@flash</div>
                }
                @RenderBody()
            </div>
        }
    </main>
    <footer class="hrm-footer py-4 mt-auto">
        <div class="container small">
            <div class="row g-3 align-items-center">
                <div class="col-md-6">
                    &copy; @DateTime.UtcNow.Year <strong>BEY HR</strong>
                    <span class="text-white-50 ms-2">|</span>
                    <a class="link-light text-decoration-none ms-2" asp-controller="Home" asp-action="Privacy">Privacy</a>
                </div>
                <div class="col-md-6 text-md-end text-white-50">
                    Yagmur Yilmaz, Mehmet Efe Inan, Burcin Isik
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
