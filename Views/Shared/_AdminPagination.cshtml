@model PagedNavigationViewModel
@if (Model.TotalPages > 1)
{
    var start = (Model.Page - 1) * PagedNavigationViewModel.PageSize + 1;
    var end = Math.Min(Model.Page * PagedNavigationViewModel.PageSize, Model.TotalCount);
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-md-between gap-3 mt-4">
        <p class="small text-muted mb-0">
            @start–@end / @Model.TotalCount kayıt
        </p>
        <nav aria-label="Sayfa gezinmesi">
            <ul class="pagination mb-0">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : null)">
                    @if (Model.Page <= 1)
                    {
                        <span class="page-link">Önceki</span>
                    }
                    else
                    {
                        <a class="page-link" asp-action="@Model.ActionName" asp-route-page="@(Model.Page - 1)">Önceki</a>
                    }
                </li>
                @for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++)
                {
                    <li class="page-item @(pageNumber == Model.Page ? "active" : null)">
                        <a class="page-link" asp-action="@Model.ActionName" asp-route-page="@pageNumber">@pageNumber</a>
                    </li>
                }
                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : null)">
                    @if (Model.Page >= Model.TotalPages)
                    {
                        <span class="page-link">Sonraki</span>
                    }
                    else
                    {
                        <a class="page-link" asp-action="@Model.ActionName" asp-route-page="@(Model.Page + 1)">Sonraki</a>
                    }
                </li>
            </ul>
        </nav>
    </div>
}
