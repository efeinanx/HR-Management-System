@model JobPostingViewModel
@{
    ViewData["Title"] = "Edit job posting (Admin)";
}
<h1 class="h3 mb-4">Edit job posting</h1>
<div class="hrm-card p-4 col-lg-10">
    <form asp-action="EditJob" method="post">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
        <partial name="_JobPostingForm" model="Model" />
        <button type="submit" class="btn hrm-btn-primary">Save</button>
        <a class="btn btn-link" asp-action="AllJobs">Cancel</a>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
