@model AdminPagedViewModel<JobPosting>
@{
    ViewData["Title"] = "Tüm ilanlar";
    var pagination = ViewBag.Pagination as PagedNavigationViewModel;
}
<h1 class="h3 mb-4">@ViewData["Title"]</h1>
@if (Model.Items.Count == 0)
{
    <p class="text-secondary">Veritabanında ilan bulunmuyor.</p>
}
else
{
    <div class="table-responsive hrm-card">
        <table class="table table-hover mb-0 hrm-table">
            <thead>
                <tr>
                    <th>Başlık</th>
                    <th>Şirket</th>
                    <th>Şehir</th>
                    <th>Aktif</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var j in Model.Items)
            {
                <tr>
                    <td>@j.Title</td>
                    <td><a asp-controller="Companies" asp-action="Details" asp-route-id="@j.CompanyProfileId">@j.Company.CompanyName</a></td>
                    <td>@j.Location</td>
                    <td>@(j.IsActive ? "Evet" : "Hayır")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="EditJob" asp-route-id="@j.Id">Düzenle</a>
                        <a class="btn btn-sm btn-outline-dark" asp-action="JobAdminDetails" asp-route-id="@j.Id">Detay</a>
                        <form class="d-inline" asp-action="DeleteJob" asp-route-id="@j.Id" method="post" onsubmit="return confirm('Bu ilan silinsin mi?');">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-outline-danger" type="submit">Sil</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    @if (pagination != null)
    {
        <partial name="_AdminPagination" model="pagination" />
    }
}
