@model IList<JobPosting>
@{
    ViewData["Title"] = "All job postings";
}
<h1 class="h3 mb-4">All job postings</h1>
@if (Model.Count == 0)
{
    <p class="text-secondary">No job postings in the database.</p>
}
else
{
    <div class="table-responsive hrm-card">
        <table class="table table-hover mb-0 hrm-table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Company</th>
                    <th>Location</th>
                    <th>Active</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var j in Model)
            {
                <tr>
                    <td>@j.Title</td>
                    <td><a asp-controller="Companies" asp-action="Details" asp-route-id="@j.CompanyProfileId">@j.Company.CompanyName</a></td>
                    <td>@j.Location</td>
                    <td>@(j.IsActive ? "Yes" : "No")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="EditJob" asp-route-id="@j.Id">Edit</a>
                        <a class="btn btn-sm btn-outline-dark" asp-action="JobAdminDetails" asp-route-id="@j.Id">Details</a>
                        <form class="d-inline" asp-action="DeleteJob" asp-route-id="@j.Id" method="post" onsubmit="return confirm('Delete this job posting?');">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
