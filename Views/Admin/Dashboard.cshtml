@{
    ViewData["Title"] = "Admin dashboard";
}
<h1 class="h3 mb-2">System overview</h1>
<p class="text-secondary mb-4">@ViewBag.AdminIntro</p>
<div class="row g-3">
    <div class="col-md-4 col-lg-2">
        <div class="hrm-card p-3 hrm-stat text-center">
            <div class="text-muted small">Users</div>
            <div class="fs-3 fw-semibold">@ViewBag.TotalUsers</div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="hrm-card p-3 hrm-stat text-center">
            <div class="text-muted small">Companies</div>
            <div class="fs-3 fw-semibold">@ViewBag.CompanyCount</div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="hrm-card p-3 hrm-stat text-center">
            <div class="text-muted small">Candidates</div>
            <div class="fs-3 fw-semibold">@ViewBag.CandidateCount</div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="hrm-card p-3 hrm-stat text-center">
            <div class="text-muted small">Jobs</div>
            <div class="fs-3 fw-semibold">@ViewBag.JobCount</div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2">
        <div class="hrm-card p-3 hrm-stat text-center">
            <div class="text-muted small">Applications</div>
            <div class="fs-3 fw-semibold">@ViewBag.ApplicationCount</div>
        </div>
    </div>
</div>
<div class="mt-4">
    <a class="btn btn-outline-dark me-2" asp-action="Users">Manage users</a>
    <a class="btn btn-outline-dark" asp-action="AllJobs">Browse all jobs</a>
</div>
