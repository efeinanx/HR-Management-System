@model LoginViewModel
@{
    ViewData["Title"] = "Sign in";
}
<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="hrm-card p-4">
            <h1 class="h4 mb-3">Sign in</h1>
            <form asp-action="Login" method="post">
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                <div class="mb-3">
                    <label asp-for="UserNameOrEmail" class="form-label"></label>
                    <input asp-for="UserNameOrEmail" class="form-control" autocomplete="username" />
                    <span asp-validation-for="UserNameOrEmail" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="mb-3 form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label"></label>
                </div>
                <button type="submit" class="btn hrm-btn-primary w-100">Sign in</button>
            </form>
            <p class="small mt-3 mb-0">
                No account? <a asp-action="Register">Register</a>
            </p>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
