@{
    ViewData["Title"] = "About us";
    ViewData["FullWidthMain"] = true;
}
<section class="container py-4">
    <p class="bey-eyebrow bey-eyebrow-muted">BEY HR</p>
    <h1 class="display-6 fw-bold mb-3">We connect people with workplaces that thrive</h1>
    <p class="lead text-secondary col-lg-10">
        BEY HR helps candidates discover meaningful roles while giving companies a modern toolkit to recruit, evaluate, and grow their teams — all in one place.
    </p>
</section>

<section class="container pb-5">
    <div class="row g-3 mb-5">
        <div class="col-md-4">
            <div class="hrm-card p-4 text-center bey-stat-tile">
                <div class="display-6 fw-bold" style="color: var(--hrm-green);">500+</div>
                <div class="small text-muted">Clients partnered with BEY HR</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="hrm-card p-4 text-center bey-stat-tile">
                <div class="display-6 fw-bold" style="color: var(--hrm-green);">4+ yrs</div>
                <div class="small text-muted">Experience building hiring experiences</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="hrm-card p-4 text-center bey-stat-tile">
                <div class="display-6 fw-bold" style="color: var(--hrm-green);">98%</div>
                <div class="small text-muted">Client satisfaction score</div>
            </div>
        </div>
    </div>

    <div class="hrm-card p-4 p-lg-5 mb-4 bey-section-card">
        <h2 class="h4 fw-bold mb-3">Who we are</h2>
        <p class="text-secondary mb-0">
            BEY HR is built by students and practitioners who believe hiring should feel clear, respectful, and fast.
            We've grown from coursework at Duzce University into a confident product studio focused on pragmatic HR tooling.
        </p>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="hrm-card p-4 h-100 bey-section-card">
                <h2 class="h5 fw-bold mb-2">Our mission</h2>
                <p class="text-secondary mb-0">
                    To give every candidate a fair shot at the right opportunity and every employer the clarity to hire with confidence —
                    without needless friction or opaque processes.
                </p>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="hrm-card p-4 h-100 bey-section-card">
                <h2 class="h5 fw-bold mb-2">Our vision</h2>
                <p class="text-secondary mb-0">
                    A regional hiring platform that feels contemporary, trustworthy, and human — bridging talent and organizations through thoughtful design.
                </p>
            </div>
        </div>
    </div>

    <div class="hrm-card p-4 p-lg-5 mt-4 bey-section-card">
        <h2 class="h5 fw-bold mb-3">Our values</h2>
        <ul class="row list-unstyled g-3 mb-0">
            <li class="col-md-6"><span class="text-success fw-semibold me-2">•</span> Transparency in every hiring step</li>
            <li class="col-md-6"><span class="text-success fw-semibold me-2">•</span> Respect for candidates' time</li>
            <li class="col-md-6"><span class="text-success fw-semibold me-2">•</span> Pragmatic tools over buzzwords</li>
            <li class="col-md-6"><span class="text-success fw-semibold me-2">•</span> Iteration grounded in feedback</li>
        </ul>
    </div>
</section>

<section class="bey-team-band py-5">
    <div class="container">
        <h2 class="text-center fw-bold mb-4">Our expert team</h2>
        <p class="text-center text-secondary col-lg-8 mx-auto mb-5">
            We are three developers and Duzce University students building BEY HR with craft and curiosity.
        </p>
        <div class="row g-4 justify-content-center">
            <div class="col-md-4">
                <div class="hrm-card p-4 text-center bey-team-card">
                    <div class="bey-team-avatar mb-3">YY</div>
                    <div class="fw-semibold">Yagmur Yilmaz</div>
                    <div class="small text-muted">Developer • Duzce University</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="hrm-card p-4 text-center bey-team-card">
                    <div class="bey-team-avatar mb-3">EI</div>
                    <div class="fw-semibold">Mehmet Efe Inan</div>
                    <div class="small text-muted">Developer • Duzce University</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="hrm-card p-4 text-center bey-team-card">
                    <div class="bey-team-avatar mb-3">BI</div>
                    <div class="fw-semibold">Burcin Isik</div>
                    <div class="small text-muted">Developer • Duzce University</div>
                </div>
            </div>
        </div>
    </div>
</section>
