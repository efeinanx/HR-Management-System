@{
    ViewData["Title"] = "Contact";
    ViewData["FullWidthMain"] = true;
}
<section class="container py-4">
    <div class="col-lg-8 mx-auto">
    <p class="bey-eyebrow bey-eyebrow-muted">Get in touch</p>
    <h1 class="display-6 fw-bold mb-3">We would love to hear from you</h1>
    <p class="text-secondary mb-5">
        Reach us directly — no forms, just the essentials below.
    </p>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="hrm-card p-4 bey-section-card h-100">
                <h2 class="h6 text-muted text-uppercase letter-spacing mb-2">Phone</h2>
                <p class="mb-0 fw-semibold"><a href="tel:+903800000000">+90 (380) 000 00 00</a></p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="hrm-card p-4 bey-section-card h-100">
                <h2 class="h6 text-muted text-uppercase letter-spacing mb-2">Email</h2>
                <p class="mb-0 fw-semibold"><a href="mailto:hello@beyhr.com">hello@beyhr.com</a></p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="hrm-card p-4 bey-section-card h-100">
                <h2 class="h6 text-muted text-uppercase letter-spacing mb-2">Address</h2>
                <p class="mb-0 text-secondary">
                    BEY HR — Duzce Teknopark<br />
                    Duzce, Turkiye
                </p>
            </div>
        </div>
    </div>
    </div>
</section>
