@model IList<JobApplication>
@{
    ViewData["Title"] = "Approved candidates";
}
<h1 class="h3 mb-4">Approved candidates</h1>
@if (Model.Count == 0)
{
    <p class="text-secondary">No approved candidates yet.</p>
}
else
{
    <div class="table-responsive hrm-card">
        <table class="table table-hover mb-0 hrm-table">
            <thead>
                <tr>
                    <th>Candidate</th>
                    <th>Job</th>
                    <th>Approved on</th>
                    <th>CV</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var a in Model)
            {
                <tr>
                    <td><a asp-action="CandidateProfile" asp-route-id="@a.CandidateProfileId">@a.Candidate?.FullName</a></td>
                    <td>@a.JobPosting?.Title</td>
                    <td>@a.AppliedAt.ToLocalTime().ToString("d")</td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(a.CvFilePath))
                        {
                            <a href="@a.CvFilePath" target="_blank">View CV</a>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-dark" asp-action="ApplicationReview" asp-route-id="@a.Id">View</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
