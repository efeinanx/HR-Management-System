@model JobPosting
@{
    ViewData["Title"] = Model.Title;
}
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="h3">@Model.Title</h1>
        <p class="text-secondary mb-0">@Model.Location &middot; @Model.EmploymentType &middot; @(Model.IsActive ? "Active" : "Inactive")</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-dark" asp-action="EditJob" asp-route-id="@Model.Id">Edit</a>
        <form asp-action="DeleteJob" method="post" asp-route-id="@Model.Id" onsubmit="return confirm('Delete this job posting?');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger">Delete</button>
        </form>
    </div>
</div>
<div class="hrm-card p-4 mb-4">
    <h2 class="h6 text-muted">Description</h2>
    <div class="preserve-lines">@Model.Description</div>
</div>
<h2 class="h5 mb-3">Applications (@Model.Applications.Count)</h2>
@if (Model.Applications.Count == 0)
{
    <p class="text-secondary">No applications yet.</p>
}
else
{
    <div class="table-responsive hrm-card">
        <table class="table table-sm mb-0 hrm-table">
            <thead>
                <tr>
                    <th>Candidate</th>
                    <th>Status</th>
                    <th>Applied</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var a in Model.Applications.OrderByDescending(x => x.AppliedAt))
            {
                <tr>
                    <td>@a.Candidate?.FullName</td>
                    <td><span class="badge bg-secondary">@a.Status</span></td>
                    <td>@a.AppliedAt.ToLocalTime().ToString("d")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-dark" asp-action="ApplicationReview" asp-route-id="@a.Id">Review</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
<a class="btn btn-link ps-0" asp-action="JobPostings">Back to listings</a>
